# =============================================================================
# FactPulse Billing App — Variables d'environnement
# =============================================================================
# Copiez ce fichier : cp .env.example .env
# Puis adaptez les valeurs à votre environnement.

# --- Django -------------------------------------------------------------------

DJANGO_SETTINGS_MODULE=config.settings.prod

# Générez une clé secrète unique :
#   python3 -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-in-production

DEBUG=False

# Domaine(s) autorisé(s), séparés par des virgules
ALLOWED_HOSTS=localhost,127.0.0.1

# Domaine pour le stack self-hosted (Caddy SSL)
# Mettre le vrai domaine en production pour Let's Encrypt
DOMAIN=localhost

# Redirection SSL (mettre false si SSL géré par Caddy ou la plateforme cloud)
SECURE_SSL_REDIRECT=true

# Superuser automatique au démarrage (optionnel)
# DJANGO_SUPERUSER_EMAIL=admin@example.com
# DJANGO_SUPERUSER_PASSWORD=change-me-in-production

# --- Base de données (PostgreSQL) --------------------------------------------

POSTGRES_DB=factpulse_billing
POSTGRES_USER=factpulse
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis / Celery ----------------------------------------------------------

# En production, ajoutez un mot de passe : redis://:MOT_DE_PASSE@redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# --- Stockage S3 / MinIO -----------------------------------------------------

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=factpulse-billing
AWS_S3_ENDPOINT_URL=http://minio:9000

# --- FactPulse API (optionnel) -----------------------------------------------
# Sans ces variables, l'app fonctionne en mode dégradé :
# pas de génération Factur-X ni de transmission PDP.

FACTPULSE_API_URL=https://your-factpulse-instance.example.com
FACTPULSE_EMAIL=billing@example.com
FACTPULSE_PASSWORD=change-me-in-production

# Intervalle de polling PDP en secondes (défaut : 900 = 15 min)
PDP_POLL_INTERVAL_SECONDS=900

# --- CORS / CSRF (adapter à votre domaine) -----------------------------------

# Origines autorisées pour les requêtes cross-origin
CORS_ALLOWED_ORIGINS=https://your-domain.example.com

# Origines de confiance pour la protection CSRF (obligatoire derrière un reverse proxy)
CSRF_TRUSTED_ORIGINS=https://your-domain.example.com

# --- Sentry (optionnel) ------------------------------------------------------
# Installer d'abord : uv pip install "factpulse-billing-app[sentry]"
# Sans SENTRY_DSN, Sentry est complètement inactif (pas d'import, pas de surcoût).

# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Email --------------------------------------------------------------------

# En production, configurez un vrai backend SMTP
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@your-domain.example.com
